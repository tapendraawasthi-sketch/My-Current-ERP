# ══════════════════════════════════════════════════════════════════════════════
# Cloudflare R2 — S3-compatible object storage
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to backend/.env (or add these vars to the project root .env).
# Never commit real credentials.

# Required
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_BUCKET=your-r2-bucket-name
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key

# Optional — auto-derived from R2_ACCOUNT_ID when omitted:
# https://<account_id>.r2.cloudflarestorage.com
R2_ENDPOINT=

# Optional — custom domain or public bucket URL for generate_public_url()
R2_PUBLIC_BASE_URL=

# Optional — comma-separated additional buckets (multi-bucket support)
R2_EXTRA_BUCKETS=

# Optional tuning
R2_REGION=auto
R2_MAX_POOL_CONNECTIONS=50
R2_CONNECT_TIMEOUT=10
R2_READ_TIMEOUT=300
R2_MULTIPART_THRESHOLD_MB=8
R2_MULTIPART_CHUNK_SIZE_MB=8
R2_MAX_RETRY_ATTEMPTS=5
R2_UPLOAD_MAX_CONCURRENCY=10
R2_METADATA_CACHE_TTL_SECONDS=60
R2_METADATA_CACHE_MAX_ENTRIES=10000
R2_APP_RETRY_MAX_ATTEMPTS=3
R2_DELETE_PARALLEL_BATCHES=4
R2_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
R2_CIRCUIT_BREAKER_RECOVERY_TIMEOUT_SEC=30
R2_CIRCUIT_BREAKER_HALF_OPEN_MAX_CALLS=3
R2_REQUIRE_HTTPS=true
# R2_ALLOW_INSECURE=true
# R2_TEMP_PREFIX=_tmp/
# R2_PERMANENT_PREFIX=
R2_IO_THREAD_POOL_WORKERS=8

# Set to "true" to verify R2 on erp_bot startup (fail-fast in production)
R2_STARTUP_VERIFY=false

# ══════════════════════════════════════════════════════════════════════════════
# Knowledge document pipeline (R2 → PostgreSQL → Chroma)
# ══════════════════════════════════════════════════════════════════════════════
# Uses DATABASE_URL and REDIS_URL from above when set.
KNOWLEDGE_WORKER_ENABLED=true
KNOWLEDGE_CHROMA_PATH=
KNOWLEDGE_COLLECTION=tenant_documents
KNOWLEDGE_CHUNK_SIZE=1200
KNOWLEDGE_CHUNK_OVERLAP=200
KNOWLEDGE_EMBED_BATCH_SIZE=50
KNOWLEDGE_JOB_MAX_ATTEMPTS=5
KNOWLEDGE_WORKER_POLL_INTERVAL_SEC=2
R2_KNOWLEDGE_PREFIX=knowledge
