{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nios.local/schemas/uil/v1",
  "title": "Universal Internal Language Document",
  "description": "Canonical internal representation for all NIOS intelligence capabilities.",
  "type": "object",
  "required": ["id", "version", "action", "confidence", "goals"],
  "properties": {
    "id": { "type": "string" },
    "version": { "type": "string", "const": "1.0" },
    "source_text": { "type": "string" },
    "language": {
      "type": "object",
      "properties": {
        "detected": { "type": "string" },
        "script": { "type": "string", "enum": ["devanagari", "roman", "english", "mixed", "unknown"] },
        "canonical_text": { "type": "string" }
      }
    },
    "action": { "type": "string" },
    "actor": {
      "type": "object",
      "properties": {
        "party": { "type": "string" },
        "role": { "type": "string" }
      }
    },
    "object": { "type": "object", "additionalProperties": true },
    "financial_effect": { "type": "object", "additionalProperties": true },
    "legal_effect": { "type": "object", "additionalProperties": true },
    "inventory_effect": { "type": "object", "additionalProperties": true },
    "tax_effect": { "type": "object", "additionalProperties": true },
    "evidence_needed": { "type": "array", "items": { "type": "string" } },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "goals": { "type": "array", "items": { "type": "string" } },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "metadata": { "type": "object", "additionalProperties": true }
  }
}
