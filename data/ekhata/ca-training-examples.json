{
  "version": "1.0.0",
  "description": "CA-level accounting entry training corpus for e-Khata. Each example maps a natural-language narration to the correct intent, journal lines, and account classification.",
  "metadata": {
    "jurisdiction": "Nepal",
    "framework": "NAS/IFRS-aligned double-entry",
    "vat_rate": 0.13,
    "ssf_employee_rate": 0.1,
    "ssf_employer_rate": 0.11,
    "account_classes": ["asset", "liability", "equity", "income", "expense", "gain", "loss", "stock"]
  },
  "classification_rules": {
    "asset": {
      "definition": "Resources with future economic benefit owned by the business",
      "debit_when": "Asset increases — purchase, receipt, accrual of receivable",
      "credit_when": "Asset decreases — payment, sale, write-off, depreciation",
      "examples": ["Cash", "Bank", "Sundry Debtors", "Stock", "Fixed Assets", "Prepaid Expenses", "Input VAT"]
    },
    "liability": {
      "definition": "Obligations owed to outsiders",
      "debit_when": "Liability decreases — payment, settlement",
      "credit_when": "Liability increases — credit purchase, accrual, provision, statutory dues",
      "examples": ["Sundry Creditors", "Loan Payable", "SSF Payable", "VAT Payable", "Salary Payable", "Gratuity Provision"]
    },
    "equity": {
      "definition": "Owner's residual interest in the business",
      "debit_when": "Equity decreases — drawings, loss transfer",
      "credit_when": "Equity increases — capital introduced, profit transfer",
      "examples": ["Capital Account", "Retained Earnings", "Drawings"]
    },
    "income": {
      "definition": "Revenue from ordinary activities and other inflows",
      "debit_when": "Income reversed or reduced",
      "credit_when": "Income earned — sale, service rendered, other income received",
      "examples": ["Sales Revenue", "Interest Received", "Rent Received", "Discount Received", "Bad Debt Recovered"]
    },
    "expense": {
      "definition": "Costs incurred to earn revenue",
      "debit_when": "Expense incurred — bill received, payment, accrual",
      "credit_when": "Expense reversed or prepaid adjustment",
      "examples": ["Rent", "Salary", "Electricity", "Depreciation", "Bad Debts", "Bank Charges", "SSF Employer"]
    },
    "gain": {
      "definition": "Profit on disposal of assets above book value",
      "debit_when": "Gain reversed",
      "credit_when": "Asset sold above written-down value",
      "examples": ["Gain on sale of machinery"]
    },
    "loss": {
      "definition": "Loss on disposal below book value",
      "debit_when": "Asset sold below book value or written off",
      "credit_when": "Loss reversed",
      "examples": ["Loss on sale of vehicle"]
    },
    "stock": {
      "definition": "Inventory held for sale or production",
      "debit_when": "Stock purchased or manufactured",
      "credit_when": "Stock sold (COGS) or written down",
      "examples": ["Raw Materials", "Finished Goods", "Trading Stock"]
    }
  },
  "situation_guide": [
    {
      "situation": "Customer buys on credit (udhaar)",
      "when": "Goods/services delivered but payment not yet received",
      "intent": "khata_credit_sale",
      "entry": "Dr Sundry Debtors, Cr Sales",
      "class_affected": "asset (debtor increases), income (sales recognised)"
    },
    {
      "situation": "Customer pays outstanding amount",
      "when": "Cash/bank received against previous credit sale",
      "intent": "khata_payment_in",
      "entry": "Dr Cash/Bank, Cr Sundry Debtors",
      "class_affected": "asset (cash up, debtor down)"
    },
    {
      "situation": "Supplier sells on credit",
      "when": "Goods received but payment not yet made",
      "intent": "khata_credit_purchase",
      "entry": "Dr Purchase/Stock, Cr Sundry Creditors",
      "class_affected": "expense/stock up, liability (creditor) up"
    },
    {
      "situation": "Bad debt — debtor cannot pay",
      "when": "Receivable confirmed irrecoverable",
      "intent": "khata_bad_debt_writeoff",
      "entry": "Dr Bad Debts Expense, Cr Sundry Debtors",
      "class_affected": "expense up, asset (debtor) down"
    },
    {
      "situation": "Provision for doubtful debts",
      "when": "End of period — conservatism, expected losses not yet confirmed",
      "intent": "khata_provision_bad_debt",
      "entry": "Dr Bad Debts Expense, Cr Provision for Bad Debts",
      "class_affected": "expense up, liability (provision) up"
    },
    {
      "situation": "Salary for the month (not yet paid)",
      "when": "Month-end accrual before payment date",
      "intent": "khata_salary_accrual",
      "entry": "Dr Salary Expense, Cr Salary Payable",
      "class_affected": "expense up, liability up"
    },
    {
      "situation": "SSF employee contribution",
      "when": "Processing payroll — 10% deducted from employee",
      "intent": "khata_ssf_employee",
      "entry": "Dr Salary (gross), Cr SSF Employee Payable + Net Salary Payable",
      "class_affected": "expense up, liability (SSF) up"
    },
    {
      "situation": "SSF employer contribution",
      "when": "Employer's 11% share on basic salary",
      "intent": "khata_ssf_employer",
      "entry": "Dr SSF Employer Expense, Cr SSF Employer Payable",
      "class_affected": "expense up, liability up"
    },
    {
      "situation": "Gratuity provision",
      "when": "Annual/monthly provision for employee retirement benefit",
      "intent": "khata_gratuity_provision",
      "entry": "Dr Gratuity Expense, Cr Gratuity Provision",
      "class_affected": "expense up, liability up"
    },
    {
      "situation": "VAT-inclusive sale",
      "when": "Registered VAT business sells with 13% VAT",
      "intent": "khata_vat_sales",
      "entry": "Dr Debtor (gross), Cr Sales (net) + Output VAT",
      "class_affected": "asset up, income up, liability (VAT) up"
    },
    {
      "situation": "VAT payment to IRD",
      "when": "Net VAT remitted to tax authority",
      "intent": "khata_vat_payment",
      "entry": "Dr Output VAT Payable, Cr Bank",
      "class_affected": "liability down, asset (bank) down"
    },
    {
      "situation": "TDS deducted on service payment",
      "when": "Paying contractor/supplier with tax withheld",
      "intent": "khata_tds_deducted",
      "entry": "Dr Expense (gross), Cr TDS Payable + Bank (net)",
      "class_affected": "expense up, liability (TDS) up"
    },
    {
      "situation": "Outstanding expense (bill received, unpaid)",
      "when": "Accrual basis — expense incurred but not paid",
      "intent": "khata_outstanding_expense",
      "entry": "Dr Expense, Cr Outstanding Expenses",
      "class_affected": "expense up, liability up"
    },
    {
      "situation": "Depreciation",
      "when": "Periodic allocation of fixed asset cost",
      "intent": "khata_depreciation",
      "entry": "Dr Depreciation Expense, Cr Accumulated Depreciation",
      "class_affected": "expense up, contra-asset up"
    },
    {
      "situation": "Capital introduced by owner",
      "when": "Owner invests cash into business",
      "intent": "khata_capital_introduced",
      "entry": "Dr Bank, Cr Capital",
      "class_affected": "asset up, equity up"
    },
    {
      "situation": "Owner drawings",
      "when": "Owner withdraws cash for personal use",
      "intent": "khata_drawings",
      "entry": "Dr Drawings, Cr Cash",
      "class_affected": "equity down, asset down"
    },
    {
      "situation": "Stock purchase",
      "when": "Inventory acquired for resale",
      "intent": "khata_stock_purchase",
      "entry": "Dr Stock, Cr Cash/Creditor",
      "class_affected": "stock up, asset/liability down"
    },
    {
      "situation": "COGS on stock sale",
      "when": "Matching principle — cost of inventory sold",
      "intent": "khata_stock_sale_cogs",
      "entry": "Dr COGS/Purchase, Cr Stock",
      "class_affected": "expense up, stock down"
    }
  ],
