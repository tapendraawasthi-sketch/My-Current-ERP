  "conflict_rules": [
    {
      "description": "Compliance questions: legal-compliance beats general and beats accounting-standards on tax rates/filing",
      "when_task": ["compliance_qa"],
      "prefer_segment_prefix": "professional.legal-compliance"
    },
    {
      "description": "Framework/recognition questions: accounting-standards beats general concepts",
      "when_task": ["framework_qa", "accounting_qa", "education"],
      "prefer_segment_prefix": "professional.accounting-standards"
    },
    {
      "description": "Language understanding: general.language beats professional for grammar/romanization",
      "when_task": ["language", "nlu", "casual"],
      "prefer_segment_prefix": "general.language"
    },
    {
      "description": "Intent code mapping: intent-taxonomy beats plain language examples for stable SAL/PUR/EXP labels",
      "when_task": ["nlu", "journal_entry"],
      "prefer_segment_prefix": "general.intent-taxonomy"
    },
    {
      "description": "Journal entries: accounting-standards + legal tax segments over plain glossary",
      "when_task": ["journal_entry"],
      "prefer_segment_prefix": "professional"
    }
  ],
  "legacy_sources": {
