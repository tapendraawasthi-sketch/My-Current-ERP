# Database (Render PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/busy_erp_prod

# Redis (Render Redis)
REDIS_URL=redis://user:password@host:6379

# Backend (Render Node.js)
NODE_ENV=production
PORT=3000
API_URL=https://busy-api.onrender.com
API_SECRET_KEY=your-secret-jwt-key-here

# Frontend (Vercel Next.js)
NEXT_PUBLIC_API_URL=https://busy-api.onrender.com
NEXT_PUBLIC_APP_NAME=BUSY ERP

# Cloudflare R2 (object storage — see backend/.env.example for full list)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_BUCKET=your-r2-bucket-name
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_ENDPOINT=
R2_PUBLIC_BASE_URL=
R2_STARTUP_VERIFY=false

# Email (SendGrid)
SENDGRID_API_KEY=your-sendgrid-key
SENDER_EMAIL=noreply@busy-erp.com

# Auth
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# GST Integration
GSP_PROVIDER=webtel
GSP_USERNAME=your-gsp-username
GSP_PASSWORD=your-gsp-password
EWB_API_KEY=your-ewb-api-key

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Mobile Khata payments
ESEWA_MERCHANT_ID=your-esewa-merchant-id
KHALTI_PUBLIC_KEY=your-khalti-public-key
PAYMENT_WEBHOOK_SECRET=your-webhook-secret

# e-Khata / Falcon / Orbix — OIP Provider Runtime (Groq on Render)
#
# RENDER (production):
#   Two services in render.yaml: sutra-erp (Node) + sutra-erp-bot (Python).
#   ERP_BOT_BACKEND_URL is auto-wired from sutra-erp-bot RENDER_EXTERNAL_URL.
#   Set OIP_GROQ_API_KEY on sutra-erp-bot only.
#   Do NOT use Google Cloud GPU / Ollama / 35.202.84.218 in production.
#
# LOCAL DEV:
#   erp_bot on :8765 with OIP_PROVIDER=groq — npm run dev on :5173
ERP_BOT_BACKEND_URL=
# Optional override (usually leave empty on Render):
VITE_ERP_BOT_URL=

# NIOS v3 Platform — unified intelligence gateway
VITE_NIOS_PLATFORM_V3=true
# Backend memory bus (erp_bot): NIOS_MEMORY_BACKEND=postgres NIOS_PG_URL=...
# Force template brain only (emergency): VITE_SELF_CONTAINED_AI=true

# Orbix v2 reasoning agent (runs inside erp_bot; these are for local reference)
# Ollama runs here:
OLLAMA_BASE_URL=http://localhost:11434
# erp_bot FastAPI (Orbix router mounted at /orbix):
# ERP_BOT_API_URL=http://localhost:8765
ORBIX_AGENT_MODEL=qwen3:14b
ORBIX_VERIFIER_MODEL=qwen3:14b
ORBIX_ROUTER_MODEL=qwen3:4b
ORBIX_EMBED_MODEL=nomic-embed-text

# Orbix Nepali Language KB (ONLI) — interpretation-only; never grants posting.
# Default enabled after owner attestation; rollback: set false.
ORBIX_NP_KB_ENABLED=true
ORBIX_NP_KB_ROOT=
ORBIX_NP_KB_LEXICAL_ENABLED=true
ORBIX_NP_KB_SEMANTIC_ENABLED=false
ORBIX_NP_KB_LEXICAL_TOP_K=8
ORBIX_NP_KB_SEMANTIC_TOP_K=8
ORBIX_NP_KB_MIN_QUALITY_SCORE=0.35
ORBIX_NP_KB_REVIEW_POLICY=development_all
ORBIX_NP_KB_CITATIONS_ENABLED=true
