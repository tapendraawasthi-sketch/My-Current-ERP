# Database (Render PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/busy_erp_prod

# Redis (Render Redis)
REDIS_URL=redis://user:password@host:6379

# Backend (Render Node.js)
NODE_ENV=production
PORT=3000
API_URL=https://busy-api.onrender.com
API_SECRET_KEY=your-secret-jwt-key-here

# Frontend (Vercel Next.js)
NEXT_PUBLIC_API_URL=https://busy-api.onrender.com
NEXT_PUBLIC_APP_NAME=BUSY ERP

# AWS S3 (for file uploads)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=busy-erp-uploads

# Email (SendGrid)
SENDGRID_API_KEY=your-sendgrid-key
SENDER_EMAIL=noreply@busy-erp.com

# Auth
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# GST Integration
GSP_PROVIDER=webtel
GSP_USERNAME=your-gsp-username
GSP_PASSWORD=your-gsp-password
EWB_API_KEY=your-ewb-api-key

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Mobile Khata payments
ESEWA_MERCHANT_ID=your-esewa-merchant-id
KHALTI_PUBLIC_KEY=your-khalti-public-key
PAYMENT_WEBHOOK_SECRET=your-webhook-secret

# e-Khata / Falcon / Orbix — Qwen-only (free, local Ollama via erp_bot)
#
# RENDER (production web):
#   ERP_BOT_BACKEND_URL=http://YOUR_GPU_SERVER_IP:8765
#   (VITE_ERP_BOT_URL is optional — frontend uses /erp-bot proxy automatically)
#
# GPU SERVER (L4 with Ollama):
#   ollama pull qwen3:32b && ollama pull qwen3:4b && ollama pull nomic-embed-text
#   cd erp_bot && python scripts/start.py
#
# LOCAL DEV:
#   erp_bot on :8765, Ollama on :11434 — no env vars needed
ERP_BOT_BACKEND_URL=
# Optional override (usually leave empty on Render):
VITE_ERP_BOT_URL=
# Force template brain only (emergency): VITE_SELF_CONTAINED_AI=true

# Orbix v2 reasoning agent (runs inside erp_bot; these are for local reference)
# Ollama runs here:
OLLAMA_BASE_URL=http://localhost:11434
# erp_bot FastAPI (Orbix router mounted at /orbix):
# ERP_BOT_API_URL=http://localhost:8765
ORBIX_AGENT_MODEL=qwen3:14b
ORBIX_VERIFIER_MODEL=qwen3:14b
ORBIX_ROUTER_MODEL=qwen3:4b
ORBIX_EMBED_MODEL=nomic-embed-text
