{
  "name": "sutra-erp",
  "private": true,
  "sideEffects": [
    "*.css"
  ],
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "setup": "mkdir -p public/uploads/logos",
    "dev": "vite dev",
    "ui:render": "npm run build && node serve.mjs",
    "start": "node serve.mjs",
    "build": "python3 erp_bot/scripts/export_nepal_ai_runtime_maps.py && node scripts/build-falcon-page-index.mjs && NODE_OPTIONS=--max-old-space-size=6144 vite build",
    "falcon:index": "node scripts/build-falcon-page-index.mjs",
    "build:dev": "vite build --mode development",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "postinstall": "echo 'Dependencies installed successfully'",
    "test:intents": "npx tsx scripts/test-falcon-intents.ts",
    "test:web-policy": "npx tsx scripts/test-web-search-policy.ts",
    "test:falcon": "npm run test:intents && npm run test:web-policy",
    "test:ekhata": "npx tsx scripts/test-ekhata-language.ts",
    "test:ekhata-ca": "npx tsx scripts/test-ekhata-ca-entries.ts",
    "test:ekhata-brain": "npx tsx scripts/test-ekhata-brain.ts",
    "test:ekhata-framework": "npx tsx scripts/test-ekhata-framework.ts",
    "test:ekhata-benchmark": "npx tsx scripts/test-ekhata-benchmark.ts",
    "eval:ekhata-v2": "npx tsx scripts/eval-ekhata-benchmark.ts",
    "test:ekhata-builtin": "npx tsx scripts/verify-builtin-brain.ts",
    "test:ekhata-corpus-benchmark": "npx tsx scripts/test-ekhata-corpus-benchmark.ts",
    "test:ekhata-parser-parity": "npx tsx scripts/test-ekhata-parser-parity.ts",
    "test:ekhata-panel-smoke": "npx tsx scripts/test-ekhata-panel-smoke.ts",
    "test:ekhata-compound": "npx tsx scripts/test-compound-splitter.ts",
    "nepal-ai:generate": "python3 erp_bot/scripts/generate_nepal_ai_language_batches_05_10.py && python3 erp_bot/scripts/bootstrap_nepal_ai_quality_data.py",
    "nepal-ai:quality": "python3 erp_bot/scripts/bootstrap_nepal_ai_quality_data.py && python3 erp_bot/scripts/bootstrap_nepal_ai_extended_quality.py && python3 erp_bot/scripts/bootstrap_nepal_ai_knowledge_batches.py",
    "nepal-ai:ingest": "python3 erp_bot/scripts/ingest_nepal_ai_language_batches.py && python3 erp_bot/scripts/ingest_nepal_ai_extended_batches.py",
    "nepal-ai:export": "python3 erp_bot/scripts/export_nepal_ai_runtime_maps.py",
    "test:e2e:ekhata": "playwright test e2e/ekhata-panel.spec.ts",
    "test:e2e:ekhata:install": "playwright install chromium",
    "test:sutra-ai": "npx tsx scripts/test-sutra-ai.ts",
    "test:ai-runtime": "npx tsx scripts/test-ai-runtime.ts",
    "test:ai-runtime-payment": "npx tsx scripts/test-ai-runtime-payment.ts",
    "generate:ekhata-corpus": "npx tsx scripts/generate-ekhata-training-corpus.ts",
    "validate:ekhata-corpus": "npx tsx scripts/validate-ekhata-corpus.ts",
    "build:ca-knowledge": "node scripts/build-conceptual-framework-knowledge.mjs",
    "test:accounting": "vitest run src/__tests__/accounting/",
    "test:orbix-contract": "vitest run src/__tests__/orbix/",
    "test:prod-ready-honesty": "python erp_bot/scripts/run_prod_ready_honesty_pytest.py",
    "test:prod-ready-orbix": "node scripts/run_prod_ready_orbix_vitest.mjs",
    "test:prod-ready-hygiene": "bash scripts/run_prod_ready_hygiene.sh",
    "test:e2e:orbix-launch-slice": "playwright test e2e/orbix-next12-launch-slice.spec.ts",
    "test:mai04-eval": "cd erp_bot && python -m pytest tests/oip/evaluation -q && python -m src.oip.evaluation.cli validate --manifest ../evals/mai04/manifests/MAI_04_FROZEN_V1.manifest.json",
    "test:e2e:orbix-connected": "playwright test e2e/orbix-connected.spec.ts",
    "check:no-emitted-js": "node scripts/check-no-emitted-js.mjs",
    "ui:audit": "node scripts/ui-audit.mjs",
    "ui:governance": "node scripts/ui-governance-check.mjs",
    "ui:governance:baseline": "node scripts/ui-governance-check.mjs --write-baseline",
    "ui:baseline": "playwright test e2e/ui-baseline.spec.ts",
    "ui:a11y": "playwright test e2e/ui-a11y-baseline.spec.ts",
    "ui:auth-baseline": "playwright test e2e/ui-auth-baseline.spec.ts",
    "ui:ds-lab": "playwright test e2e/ui-ds-lab.spec.ts",
    "ui:phase2": "playwright test e2e/ui2-lab.spec.ts",
    "ui:phase3": "playwright test e2e/ui3-shell.spec.ts",
    "ui:phase4": "playwright test e2e/ui4-auth.spec.ts",
    "ui:phase5": "playwright test e2e/ui5-home.spec.ts",
    "ui:phase6": "playwright test e2e/ui6-orbix.spec.ts",
    "ui:phase7": "playwright test e2e/ui7-txn.spec.ts",
    "ui:route-smoke": "node scripts/ui3-route-smoke.mjs",
    "kb:status": "python knowledgebase/scripts/run_kb_pipeline.py --status-only",
    "kb:eval": "python knowledgebase/scripts/run_kb_evaluation.py",
    "kb:smoke": "python knowledgebase/scripts/smoke_test_retrieval.py --enable",
    "kb:gate": "python knowledgebase/scripts/phase8_release_gate.py",
    "kb:closeout": "python knowledgebase/scripts/complete_owner_closeout.py",
    "kb:rollback-drill": "python knowledgebase/scripts/staging_enable_rollback_drill.py",
    "kb:must-review": "python knowledgebase/scripts/export_must_review_packet.py",
    "kb:specialist": "python knowledgebase/scripts/build_specialist_and_defer_batch.py --skip-defer",
    "kb:review-lab": "python knowledgebase/scripts/build_review_lab.py",
    "kb:priority-queue": "python knowledgebase/scripts/export_priority_review_queue.py",
    "kb:apply-overlays": "python knowledgebase/scripts/apply_review_overlays.py",
    "kb:test": "python -m pytest knowledgebase/tests -q"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/lib-storage": "^3.1075.0",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
