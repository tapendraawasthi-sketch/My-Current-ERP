# Database
DATABASE_URL=postgresql://user:password@localhost:5432/busy_erp_dev

# Redis
REDIS_URL=redis://localhost:6379

# Server
NODE_ENV=development
PORT=3000

# JWT
JWT_SECRET=your-secret-key-min-32-characters
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-key
AWS_SECRET_ACCESS_KEY=your-secret
AWS_S3_BUCKET=busy-erp-uploads

# Email
SENDGRID_API_KEY=your-sendgrid-key
SENDER_EMAIL=noreply@busy-erp.com

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# GST
GSP_PROVIDER=webtel
GSP_USERNAME=your-username
GSP_PASSWORD=your-password
