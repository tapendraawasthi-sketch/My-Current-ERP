{
  "name": "@busy-erp/backend",
  "version": "1.0.0",
  "description": "BUSY ERP Backend API (Node.js + NestJS)",
  "main": "dist/main.js",
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "test:cov": "jest --coverage",
    "db:migrate": "typeorm migration:run -d src/database/data-source.ts",
    "db:generate": "typeorm migration:generate -d src/database/data-source.ts",
    "db:seed": "ts-node src/database/seeders/index.ts",
    "health": "curl http://localhost:3000/api/health"
  },
  "dependencies": {
    "@nestjs/common": "^10.2.0",
    "@nestjs/core": "^10.2.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/typeorm": "^9.0.0",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.0",
    "typeorm": "^0.3.16",
    "pg": "^8.10.0",
    "redis": "^4.6.0",
    "bullmq": "^4.10.0",
    "aws-sdk": "^2.1450.0",
    "axios": "^1.5.0",
    "class-validator": "^0.14.0",
    "class-transformer": "^0.5.0",
    "decimal.js": "^10.4.0",
    "helmet": "^7.0.0",
    "cors": "^2.8.5",
    "compression": "^1.7.4",
    "pino": "^8.14.0",
    "pino-http": "^8.3.0",
    "dotenv": "^16.3.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.2.0",
    "@nestjs/schematics": "^10.0.0",
    "@types/node": "^20.5.0",
    "@types/jest": "^29.5.0",
    "@typescript-eslint/eslint-plugin": "^6.4.0",
    "@typescript-eslint/parser": "^6.4.0",
    "eslint": "^8.46.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.2.0",
    "supertest": "^6.3.0"
  }
}
