# erp_bot — local dev (Ollama legacy) or Render production (OIP + Groq)
OLLAMA_BASE_URL=http://localhost:11434

# ══════════════════════════════════════════════════════════════════════════════
# RENDER PRODUCTION (sutra-erp-bot service — see render.yaml)
# ══════════════════════════════════════════════════════════════════════════════
# OIP_ENABLED=true
# OIP_FORCE_STUB_PROVIDERS=false
# OIP_PROVIDER=groq
# OIP_GROQ_API_KEY=<secret — set in Render dashboard only>
# OIP_DEFAULT_MODEL=llama-3.3-70b-versatile
# OIP_AUTH_REQUIRED=false
# Start: python scripts/start_render.py  (uses PORT from Render)

# ══════════════════════════════════════════════════════════════════════════════
# PHASE 1 — CONVERSATION BRAIN
# ══════════════════════════════════════════════════════════════════════════════
# For L4 GPU (24GB VRAM), use the largest Qwen3 you can fit:
#   - qwen3:32b (recommended, needs Q4/Q5 quantization)
#   - qwen3:14b (fallback if 32B doesn't fit)
#   - qwen3:8b  (minimal)

# Primary conversational model — warm, natural, tri-lingual (EN/Nepali/Romanized)
# This is the "brain" that talks to users. Use the largest Qwen3 your GPU can handle.
CONVERSATIONAL_MODEL=qwen3:32b
# Alternatively: qwen3:32b-q4_K_M for 4-bit quantized version

# Fast model for routing, classification, quick extractions (<3s response)
FAST_MODEL_NAME=qwen3:4b

# Embeddings for RAG retrieval
EMBED_MODEL=nomic-embed-text

# Context window size — L4 can handle 8K-12K comfortably with 32B quantized
# Increase if you have more VRAM, decrease if you see OOM errors
CONTEXT_SIZE=8192

# Generation parameters for natural conversation
TEMPERATURE=0.7
TOP_P=0.9
REPEAT_PENALTY=1.1

# How many conversation turns to keep in memory (each turn = 1 user + 1 assistant)
MAX_CONVERSATION_TURNS=10

# ══════════════════════════════════════════════════════════════════════════════
# LEGACY MODEL ALIASES (backward compatibility)
# ══════════════════════════════════════════════════════════════════════════════
MODEL_NAME=qwen3:32b
DEEP_MODEL_NAME=qwen3:32b

# ══════════════════════════════════════════════════════════════════════════════
# API & PATHS
# ══════════════════════════════════════════════════════════════════════════════
API_PORT=8765
ERP_PATH=

# ══════════════════════════════════════════════════════════════════════════════
# KHATA / NLU SETTINGS
# ══════════════════════════════════════════════════════════════════════════════
# Enable fast LLM JSON fallback when regex parser misses
KHATA_USE_STRUCTURED_PARSE=true
KHATA_SYNTHESIZE_CONTEXT=true

# Regex confidence threshold — below this, always use LLM for parsing
NLU_REGEX_THRESHOLD=0.85

# ══════════════════════════════════════════════════════════════════════════════
# ORBIX v2 (genuine reasoning agent) — Phase 2+
# ══════════════════════════════════════════════════════════════════════════════
# Role-specialized models. Defaults reuse the models above; override to use
# stronger code models once pulled (ollama pull qwen2.5-coder:14b, bge-m3, ...).
ORBIX_AGENT_MODEL=qwen3:32b
ORBIX_VERIFIER_MODEL=qwen3:32b
ORBIX_ROUTER_MODEL=qwen3:4b
ORBIX_EMBED_MODEL=nomic-embed-text
ORBIX_MAX_TOOL_STEPS=8
# ORBIX_MEMORY_DB=data/orbix_memory.sqlite3

# ══════════════════════════════════════════════════════════════════════════════
# OIP — Orbix Intelligence Platform (Constitutional Architecture Phase 0)
# ══════════════════════════════════════════════════════════════════════════════
OIP_ENABLED=true
OIP_FACADE_LEGACY=false
OIP_EXECUTION_MODE=native
OIP_SHADOW_AUDIT=true
OIP_SHADOW_LINEAGE=true
OIP_CONVERSATION_ENABLED=true
OIP_SHADOW_CONVERSATION=true
OIP_SESSION_ENABLED=true
OIP_SHADOW_SESSION=true
OIP_PLANNER_ENABLED=true
OIP_SHADOW_PLANNER=true
OIP_ROUTER_ENABLED=true
OIP_SHADOW_ROUTER=true
OIP_ROUTER_POLICY=balanced
OIP_PROVIDER_RUNTIME_ENABLED=true
OIP_SHADOW_PROVIDER_RUNTIME=true
OIP_STREAMING_ENABLED=true
OIP_PROVIDER_POLICY=balanced
OIP_FORCE_STUB_PROVIDERS=true
OIP_PROVIDER_OFFLINE_MODE=false
OIP_PROVIDER_TIMEOUT_SECONDS=60
# Production Groq example (set OIP_FORCE_STUB_PROVIDERS=false and provide API key):
# OIP_PROVIDER=groq
# OIP_DEFAULT_MODEL=llama-3.3-70b-versatile
# OIP_GROQ_API_KEY=
# OIP_OPENAI_API_KEY=
# OIP_ANTHROPIC_API_KEY=
# OIP_GOOGLE_API_KEY=
OIP_OLLAMA_BASE_URL=http://127.0.0.1:11434
OIP_DATABASE_URL=sqlite+aiosqlite:///./data/oip/oip.db
# OIP_EDITION=cloud
# OIP_DEPLOYMENT_MODE=cloud_saas

# ══════════════════════════════════════════════════════════════════════════════
# PHASE 6 — LATENCY & UX OPTIMIZATION
# ══════════════════════════════════════════════════════════════════════════════

# Keep model loaded in VRAM (avoids 12s cold start)
# Format: "10m" = 10 minutes, "1h" = 1 hour, "-1" = forever
OLLAMA_KEEP_ALIVE=10m

# Concurrent requests (2 allows fast+main model to run together)
OLLAMA_NUM_PARALLEL=2

# Response caching for repeated questions
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE=500

# Streaming chunk size (characters per SSE event)
STREAMING_CHUNK_SIZE=10

# NIOS v3 — Financial Intelligence Platform
# ══════════════════════════════════════════════════════════════════════════════
NIOS_PLATFORM_V3=true
# Memory bus: sqlite (default) or postgres
# NIOS_MEMORY_BACKEND=postgres
# NIOS_PG_URL=postgresql://user:pass@host:5432/erp
# Self-hosted feed export (when erp_bot running on :8765):
# NIOS_NEPSE_FEED_URL=http://127.0.0.1:8765/nios/v1/feeds/export/nepse
# NIOS_GOV_FEED_URL=http://127.0.0.1:8765/nios/v1/feeds/export/gov
# NIOS_DATA_DIR=data

# ══════════════════════════════════════════════════════════════════════════════
# OIP — Security, Identity & Multi-Tenancy (Phase 2.8)
# ══════════════════════════════════════════════════════════════════════════════
# OIP_AUTH_REQUIRED=false
# OIP_TENANT_ENFORCEMENT=true
# OIP_JWT_SECRET=change-me-in-production
# OIP_JWT_ISSUER=sutra-oip
# OIP_JWT_AUDIENCE=sutra-oip
# OIP_JWT_ACCESS_TTL_MINUTES=60
# OIP_JWT_REFRESH_TTL_DAYS=30
# OIP_API_KEYS=
# OIP_CREDENTIAL_ENCRYPTION_KEY=
# OIP_RATE_LIMIT_MAX=120
# OIP_RATE_LIMIT_WINDOW_SECONDS=60
# OIP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8765
# OIP_CSRF_PROTECTION=false

# ══════════════════════════════════════════════════════════════════════════════
# OIP — Operations & Observability (Phase 2.9)
# ══════════════════════════════════════════════════════════════════════════════
# OIP_OUTBOX_MAX_ATTEMPTS=5
# OIP_OUTBOX_POLLER_ENABLED=false
# OIP_OUTBOX_POLLER_INTERVAL_SECONDS=5
# OIP_OPS_ALERT_DLQ_THRESHOLD=10
# OIP_OPS_ALERT_QUEUE_THRESHOLD=500
# ══════════════════════════════════════════════════════════════════════════════
# MODEL_NAME=ekhata-ca:7b
# CONVERSATIONAL_MODEL=sutra-orbix:32b
