# erp_bot — local Ollama LLM (no API keys)
OLLAMA_BASE_URL=http://localhost:11434

# MODEL 1: Primary chat + reasoning (pull: ollama pull qwen3:14b)
MODEL_NAME=qwen3:14b

# MODEL 2: Fast structured extraction (pull: ollama pull qwen3:4b)
FAST_MODEL_NAME=qwen3:4b

# MODEL 3: Embeddings for RAG (pull: ollama pull nomic-embed-text)
EMBED_MODEL=nomic-embed-text

API_PORT=8765
ERP_PATH=

# Enable fast LLM JSON fallback when regex parser misses
KHATA_USE_STRUCTURED_PARSE=true
KHATA_SYNTHESIZE_CONTEXT=true

# Legacy fine-tuned model (optional, after LoRA training):
# MODEL_NAME=ekhata-ca:7b

# ── Orbix v2 (genuine reasoning agent) ──────────────────────────────────────
# Role-specialised models. Defaults reuse the models above; override to use
# stronger code models once pulled (ollama pull qwen2.5-coder:14b, bge-m3, ...).
ORBIX_AGENT_MODEL=qwen3:14b
ORBIX_VERIFIER_MODEL=qwen3:14b
ORBIX_ROUTER_MODEL=qwen3:4b
ORBIX_EMBED_MODEL=nomic-embed-text
ORBIX_MAX_TOOL_STEPS=8
# ORBIX_MEMORY_DB=data/orbix_memory.sqlite3
