# erp_bot — local Ollama LLM (no API keys)
OLLAMA_BASE_URL=http://localhost:11434

# Base instruct model (better Nepali/CA chat than coder variant)
MODEL_NAME=ekhata-ca:7b
# Before fine-tune: run bash erp_bot/training/create_base_model.sh
# After LoRA fine-tune: run bash erp_bot/training/export_to_ollama.sh

# Fallback if ekhata-ca:7b not created yet:
# MODEL_NAME=qwen2.5:7b-instruct

EMBED_MODEL=nomic-embed-text
API_PORT=8765
ERP_PATH=

# Enable LLM JSON fallback when regex parser misses (uses fine-tuned knowledge)
KHATA_USE_STRUCTURED_PARSE=true
