# erp_bot — local Ollama LLM (no API keys)
OLLAMA_BASE_URL=http://localhost:11434

# ══════════════════════════════════════════════════════════════════════════════
# PHASE 1 — CONVERSATION BRAIN
# ══════════════════════════════════════════════════════════════════════════════
# For L4 GPU (24GB VRAM), use the largest Qwen3 you can fit:
#   - qwen3:32b (recommended, needs Q4/Q5 quantization)
#   - qwen3:14b (fallback if 32B doesn't fit)
#   - qwen3:8b  (minimal)

# Primary conversational model — warm, natural, tri-lingual (EN/Nepali/Romanized)
# This is the "brain" that talks to users. Use the largest Qwen3 your GPU can handle.
CONVERSATIONAL_MODEL=qwen3:32b
# Alternatively: qwen3:32b-q4_K_M for 4-bit quantized version

# Fast model for routing, classification, quick extractions (<3s response)
FAST_MODEL_NAME=qwen3:4b

# Embeddings for RAG retrieval
EMBED_MODEL=nomic-embed-text

# Context window size — L4 can handle 8K-12K comfortably with 32B quantized
# Increase if you have more VRAM, decrease if you see OOM errors
CONTEXT_SIZE=8192

# Generation parameters for natural conversation
TEMPERATURE=0.7
TOP_P=0.9
REPEAT_PENALTY=1.1

# How many conversation turns to keep in memory (each turn = 1 user + 1 assistant)
MAX_CONVERSATION_TURNS=10

# ══════════════════════════════════════════════════════════════════════════════
# LEGACY MODEL ALIASES (backward compatibility)
# ══════════════════════════════════════════════════════════════════════════════
MODEL_NAME=qwen3:32b
DEEP_MODEL_NAME=qwen3:32b

# ══════════════════════════════════════════════════════════════════════════════
# API & PATHS
# ══════════════════════════════════════════════════════════════════════════════
API_PORT=8765
ERP_PATH=

# ══════════════════════════════════════════════════════════════════════════════
# KHATA / NLU SETTINGS
# ══════════════════════════════════════════════════════════════════════════════
# Enable fast LLM JSON fallback when regex parser misses
KHATA_USE_STRUCTURED_PARSE=true
KHATA_SYNTHESIZE_CONTEXT=true

# Regex confidence threshold — below this, always use LLM for parsing
NLU_REGEX_THRESHOLD=0.85

# ══════════════════════════════════════════════════════════════════════════════
# ORBIX v2 (genuine reasoning agent) — Phase 2+
# ══════════════════════════════════════════════════════════════════════════════
# Role-specialized models. Defaults reuse the models above; override to use
# stronger code models once pulled (ollama pull qwen2.5-coder:14b, bge-m3, ...).
ORBIX_AGENT_MODEL=qwen3:32b
ORBIX_VERIFIER_MODEL=qwen3:32b
ORBIX_ROUTER_MODEL=qwen3:4b
ORBIX_EMBED_MODEL=nomic-embed-text
ORBIX_MAX_TOOL_STEPS=8
# ORBIX_MEMORY_DB=data/orbix_memory.sqlite3

# ══════════════════════════════════════════════════════════════════════════════
# OPTIONAL: Fine-tuned models after LoRA training
# ══════════════════════════════════════════════════════════════════════════════
# MODEL_NAME=ekhata-ca:7b
# CONVERSATIONAL_MODEL=sutra-orbix:32b
