{
  "$defs": {
    "ClaimCitationStatus": {
      "enum": [
        "NOT_RUN",
        "COMPLETE",
        "SKIP",
        "FAILED"
      ],
      "title": "ClaimCitationStatus",
      "type": "string"
    },
    "ClaimCitationVerificationStatus": {
      "enum": [
        "UNVERIFIED",
        "INSUFFICIENT"
      ],
      "title": "ClaimCitationVerificationStatus",
      "type": "string"
    },
    "ClaimCueKind": {
      "enum": [
        "LEGAL_TAX",
        "ACCOUNTING_RULE",
        "ERP_FACT",
        "PRODUCT_CAPABILITY",
        "UNKNOWN"
      ],
      "title": "ClaimCueKind",
      "type": "string"
    },
    "ClaimCueV1": {
      "additionalProperties": false,
      "properties": {
        "cue_id": {
          "maxLength": 64,
          "minLength": 1,
          "title": "Cue Id",
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/ClaimCueKind",
          "default": "UNKNOWN"
        },
        "reason_codes": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Reason Codes",
          "type": "array"
        },
        "surface": {
          "default": "",
          "title": "Surface",
          "type": "string"
        }
      },
      "required": [
        "cue_id"
      ],
      "title": "ClaimCueV1",
      "type": "object"
    },
    "GroundedAnswerPolicy": {
      "enum": [
        "ABSTAIN_WHEN_UNGROUNDED",
        "UNKNOWN"
      ],
      "title": "GroundedAnswerPolicy",
      "type": "string"
    }
  },
  "$id": "https://mokxya.local/contracts/v1/ClaimCitationBundleV1.json",
  "additionalProperties": false,
  "properties": {
    "analysis_status": {
      "$ref": "#/$defs/ClaimCitationStatus",
      "default": "NOT_RUN"
    },
    "citation_required": {
      "default": true,
      "title": "Citation Required",
      "type": "boolean"
    },
    "citations_verified": {
      "default": false,
      "title": "Citations Verified",
      "type": "boolean"
    },
    "claim_cues": {
      "default": [],
      "items": {
        "$ref": "#/$defs/ClaimCueV1"
      },
      "title": "Claim Cues",
      "type": "array"
    },
    "claims_verified": {
      "default": false,
      "title": "Claims Verified",
      "type": "boolean"
    },
    "documents_retrieved": {
      "default": 0,
      "minimum": 0,
      "title": "Documents Retrieved",
      "type": "integer"
    },
    "draft_mutations": {
      "default": 0,
      "minimum": 0,
      "title": "Draft Mutations",
      "type": "integer"
    },
    "error_codes": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Error Codes",
      "type": "array"
    },
    "fake_citation_allowed": {
      "default": false,
      "title": "Fake Citation Allowed",
      "type": "boolean"
    },
    "grounded_answer_policy": {
      "$ref": "#/$defs/GroundedAnswerPolicy",
      "default": "ABSTAIN_WHEN_UNGROUNDED"
    },
    "legal_proof_claimed": {
      "default": false,
      "title": "Legal Proof Claimed",
      "type": "boolean"
    },
    "model_invocations": {
      "default": 0,
      "minimum": 0,
      "title": "Model Invocations",
      "type": "integer"
    },
    "reason_codes": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Reason Codes",
      "type": "array"
    },
    "runtime_version": {
      "default": "mai-30.0.2-slice2",
      "title": "Runtime Version",
      "type": "string"
    },
    "schema_version": {
      "title": "Schema Version",
      "type": "string"
    },
    "source_authority": {
      "default": "REQUEST",
      "title": "Source Authority",
      "type": "string"
    },
    "verification_status": {
      "$ref": "#/$defs/ClaimCitationVerificationStatus",
      "default": "UNVERIFIED"
    },
    "verifier_executed": {
      "default": false,
      "title": "Verifier Executed",
      "type": "boolean"
    },
    "warnings": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Warnings",
      "type": "array"
    }
  },
  "title": "ClaimCitationBundleV1",
  "type": "object",
  "x-mai-schema-version": "1.0.0"
}
