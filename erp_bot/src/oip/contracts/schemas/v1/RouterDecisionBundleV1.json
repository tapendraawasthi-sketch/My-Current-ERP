          "type": "string"
        },
        "original_text": {
          "title": "Original Text",
          "type": "string"
        },
        "source_message_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Message Id"
        },
        "start_offset": {
          "minimum": 0,
          "title": "Start Offset",
          "type": "integer"
        }
      },
      "required": [
        "start_offset",
        "end_offset",
        "original_text"
      ],
      "title": "SourceSpanV1",
      "type": "object"
    }
