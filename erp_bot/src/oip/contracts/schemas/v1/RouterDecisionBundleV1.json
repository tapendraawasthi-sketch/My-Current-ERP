            "$ref": "#/$defs/SourceSpanV1"
          },
          "title": "Evidence Spans",
          "type": "array"
        },
        "intent_id": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Intent Id",
          "type": "string"
        },
        "missing_context": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Missing Context",
          "type": "array"
