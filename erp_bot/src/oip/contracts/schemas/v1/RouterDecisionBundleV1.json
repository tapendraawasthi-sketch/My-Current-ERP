      "type": "string"
    },
    "EvidenceReferenceV1": {
      "additionalProperties": false,
      "properties": {
        "evidence_id": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Evidence Id",
          "type": "string"
        },
        "source_span": {
          "anyOf": [
            {
              "$ref": "#/$defs/SourceSpanV1"
            },
            {
              "type": "null"
            }
          ],
          "default": null
