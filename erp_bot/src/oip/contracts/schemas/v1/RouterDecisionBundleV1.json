        "out_of_distribution_score": {
          "default": 0.0,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Out Of Distribution Score",
          "type": "number"
        },
        "required_capability": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Required Capability"
        },
        "schema_version": {
          "title": "Schema Version",
          "type": "string"
        },
        "score": {
          "default": 0.0,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Score",
          "type": "number"
        },
        "status": {
          "$ref": "#/$defs/ContractStatus",
          "default": "NOT_RUN"
        }
      },
      "required": [
        "intent_id"
      ],
      "title": "IntentCandidateV1",
      "type": "object"
    },
    "IntentFamily": {
      "enum": [
        "TRANSACTION",
        "QUERY",
        "REPORT",
        "MASTER",
        "CLARIFY",
        "CONFIRM",
        "CANCEL",
        "QA",
        "UNKNOWN"
