        "ERP_OPS",
        "REPORTING",
        "MASTER_DATA",
        "DIALOGUE",
        "UNKNOWN"
      ],
      "title": "RouterDomain",
      "type": "string"
    },
    "SourceSpanV1": {
      "additionalProperties": false,
      "description": "Offsets are Unicode code-point indices unless offset_unit says otherwise.",
      "properties": {
        "end_offset": {
          "minimum": 0,
          "title": "End Offset",
          "type": "integer"
        },
        "offset_unit": {
          "default": "UNICODE_CODE_POINT",
