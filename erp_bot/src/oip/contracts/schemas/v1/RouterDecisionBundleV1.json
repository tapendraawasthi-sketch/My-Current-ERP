          "type": "boolean"
        },
        "is_ood": {
          "default": false,
          "title": "Is Ood",
          "type": "boolean"
        },
        "reason_codes": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Reason Codes",
          "type": "array"
        },
        "score": {
          "default": 0.0,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Score",
          "type": "number"
        }
      },
      "title": "OodSignalV1",
      "type": "object"
