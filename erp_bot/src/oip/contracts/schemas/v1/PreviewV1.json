      "type": "object"
    },
    "DraftStatus": {
      "enum": [
        "OPEN",
        "NEEDS_CLARIFICATION",
        "READY_FOR_PREVIEW",
        "PREVIEWED",
        "CANCELLED",
        "EXPIRED",
        "SUPERSEDED"
