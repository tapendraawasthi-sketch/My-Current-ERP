        "structured_payload": {
          "discriminator": {
            "mapping": {
              "ACTION_PROGRESS": "#/$defs/ActionProgressPayloadV1",
              "ANSWER": "#/$defs/AnswerPayloadV1",
              "CHOICE": "#/$defs/ChoicePayloadV1",
              "CLARIFICATION": "#/$defs/ClarificationPayloadV1",
              "CONFLICT": "#/$defs/ConflictPayloadV1",
              "DEGRADED": "#/$defs/DegradedPayloadV1",
              "DRAFT": "#/$defs/DraftPayloadV1",
              "ERROR": "#/$defs/ErrorPayloadV1",
              "PREVIEW": "#/$defs/PreviewPayloadV1",
              "RECEIPT": "#/$defs/ReceiptPayloadV1",
              "REPORT": "#/$defs/ReportPayloadV1",
              "SAFE_REFUSAL": "#/$defs/SafeRefusalPayloadV1"
            },
            "propertyName": "payload_type"
          },
          "oneOf": [
            {
              "$ref": "#/$defs/AnswerPayloadV1"
            },
            {
              "$ref": "#/$defs/ClarificationPayloadV1"
            },
            {
              "$ref": "#/$defs/ChoicePayloadV1"
            },
            {
              "$ref": "#/$defs/ReportPayloadV1"
            },
            {
              "$ref": "#/$defs/DraftPayloadV1"
            },
            {
              "$ref": "#/$defs/PreviewPayloadV1"
            },
            {
              "$ref": "#/$defs/ActionProgressPayloadV1"
            },
            {
              "$ref": "#/$defs/ReceiptPayloadV1"
            },
            {
              "$ref": "#/$defs/ConflictPayloadV1"
            },
            {
              "$ref": "#/$defs/SafeRefusalPayloadV1"
            },
            {
              "$ref": "#/$defs/DegradedPayloadV1"
            },
            {
              "$ref": "#/$defs/ErrorPayloadV1"
            }
          ],
          "title": "Structured Payload"
        },
        "suggested_safe_actions": {
          "default": [],
