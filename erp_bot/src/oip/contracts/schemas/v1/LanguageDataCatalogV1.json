{
  "$defs": {
    "AssetPresence": {
      "enum": [
        "PRESENT",
        "MISSING",
        "HASH_MISMATCH",
        "UNKNOWN"
      ],
      "title": "AssetPresence",
      "type": "string"
    },
    "LanguageDataAssetV1": {
      "additionalProperties": false,
      "properties": {
        "asset_id": {
          "title": "Asset Id",
          "type": "string"
        },
        "expected_sha256": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Expected Sha256"
        },
        "notes": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Notes"
        },
        "path": {
          "title": "Path",
          "type": "string"
        },
        "presence": {
          "$ref": "#/$defs/AssetPresence",
          "default": "UNKNOWN"
        },
        "role": {
          "$ref": "#/$defs/LanguageDataRole"
        },
        "sha256": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sha256"
        },
        "training_eligible": {
          "default": false,
          "title": "Training Eligible",
          "type": "boolean"
        }
      },
      "required": [
        "asset_id",
        "path",
        "role"
      ],
      "title": "LanguageDataAssetV1",
      "type": "object"
    },
    "LanguageDataGovernanceStatus": {
      "enum": [
        "NOT_RUN",
        "COMPLETE",
        "PARTIAL",
        "FAILED"
      ],
      "title": "LanguageDataGovernanceStatus",
      "type": "string"
    },
    "LanguageDataRole": {
      "enum": [
        "FROZEN_EVAL",
        "DEVELOPMENT",
        "SEED_ONTOLOGY",
        "RUNTIME_PACK",
        "KB_INDEX",
        "SOURCE_ARCHIVE"
      ],
      "title": "LanguageDataRole",
      "type": "string"
    }
  },
  "$id": "https://mokxya.local/contracts/v1/LanguageDataCatalogV1.json",
  "additionalProperties": false,
  "properties": {
    "analysis_status": {
      "$ref": "#/$defs/LanguageDataGovernanceStatus",
      "default": "NOT_RUN"
    },
    "assets": {
      "default": [],
      "items": {
        "$ref": "#/$defs/LanguageDataAssetV1"
      },
      "title": "Assets",
      "type": "array"
    },
    "catalog_version": {
      "default": "mai-12.catalog.v1",
      "title": "Catalog Version",
      "type": "string"
    },
    "error_codes": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Error Codes",
      "type": "array"
    },
    "frozen_training_violations": {
      "default": 0,
      "minimum": 0,
      "title": "Frozen Training Violations",
      "type": "integer"
    },
    "hash_mismatches": {
      "default": 0,
      "minimum": 0,
      "title": "Hash Mismatches",
      "type": "integer"
    },
    "missing_required": {
      "default": 0,
      "minimum": 0,
      "title": "Missing Required",
      "type": "integer"
    },
    "runtime_version": {
      "default": "mai-12.0.1-slice1",
      "title": "Runtime Version",
      "type": "string"
    },
    "schema_version": {
      "title": "Schema Version",
      "type": "string"
    },
    "warnings": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Warnings",
      "type": "array"
    }
  },
  "title": "LanguageDataCatalogV1",
  "type": "object",
  "x-mai-schema-version": "1.0.0"
}
