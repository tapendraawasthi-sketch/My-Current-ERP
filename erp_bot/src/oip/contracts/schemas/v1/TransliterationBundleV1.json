{
  "$defs": {
    "AlignmentKind": {
      "enum": [
        "ONE_TO_ONE",
        "ONE_TO_MANY",
        "MANY_TO_ONE",
        "MANY_TO_MANY",
        "IDENTITY",
        "IDENTITY_GAP"
      ],
      "title": "AlignmentKind",
      "type": "string"
    },
    "AlignmentMapV1": {
      "additionalProperties": false,
      "properties": {
        "candidate_length": {
          "minimum": 0,
          "title": "Candidate Length",
          "type": "integer"
        },
        "mapping_version": {
          "default": "mai-07.1.0",
          "title": "Mapping Version",
          "type": "string"
        },
        "offset_unit": {
          "default": "UNICODE_CODE_POINT",
          "title": "Offset Unit",
          "type": "string"
        },
        "raw_length": {
          "minimum": 0,
          "title": "Raw Length",
          "type": "integer"
        },
        "segments": {
          "default": [],
          "items": {
            "$ref": "#/$defs/AlignmentSegmentV1"
          },
          "title": "Segments",
          "type": "array"
        }
      },
      "required": [
        "raw_length",
        "candidate_length"
      ],
      "title": "AlignmentMapV1",
      "type": "object"
    },
    "AlignmentSegmentV1": {
      "additionalProperties": false,
      "properties": {
        "alignment_kind": {
          "$ref": "#/$defs/AlignmentKind",
          "default": "IDENTITY"
        },
        "candidate_end": {
          "minimum": 0,
          "title": "Candidate End",
          "type": "integer"
        },
        "candidate_start": {
          "minimum": 0,
          "title": "Candidate Start",
          "type": "integer"
        },
        "raw_end": {
          "minimum": 0,
          "title": "Raw End",
          "type": "integer"
        },
        "raw_start": {
          "minimum": 0,
          "title": "Raw Start",
          "type": "integer"
        }
      },
      "required": [
        "raw_start",
        "raw_end",
        "candidate_start",
        "candidate_end"
      ],
      "title": "AlignmentSegmentV1",
      "type": "object"
    },
    "CalibrationStatus": {
      "enum": [
        "UNCALIBRATED",
        "ENGINEERING_CALIBRATED",
        "HUMAN_REVIEW_REQUIRED"
      ],
      "title": "CalibrationStatus",
      "type": "string"
    },
    "CandidateKind": {
      "enum": [
        "IDENTITY",
        "LEXICAL",
        "GRAPHEME",
        "MORPHOLOGICAL",
        "PHRASE",
        "DOMAIN",
        "CONTEXTUAL",
        "ABSTENTION"
      ],
      "title": "CandidateKind",
      "type": "string"
    },
    "CandidateScript": {
      "enum": [
        "LATIN",
        "DEVANAGARI",
        "MIXED",
        "OTHER"
      ],
      "title": "CandidateScript",
      "type": "string"
    },
    "EligibilityDecision": {
      "enum": [
        "GENERATE",
        "IDENTITY_ONLY",
        "ABSTAIN",
        "SKIPPED_PROTECTED",
        "SKIPPED_UNSUPPORTED",
        "SKIPPED_SECURITY",
        "SKIPPED_TOO_LONG"
      ],
      "title": "EligibilityDecision",
      "type": "string"
    },
    "SourceSpanV1": {
      "additionalProperties": false,
      "description": "Offsets are Unicode code-point indices unless offset_unit says otherwise.",
      "properties": {
        "end_offset": {
          "minimum": 0,
          "title": "End Offset",
          "type": "integer"
        },
        "offset_unit": {
          "default": "UNICODE_CODE_POINT",
          "title": "Offset Unit",
          "type": "string"
        },
        "original_text": {
          "title": "Original Text",
          "type": "string"
        },
        "source_message_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Message Id"
        },
        "start_offset": {
          "minimum": 0,
          "title": "Start Offset",
          "type": "integer"
        }
      },
      "required": [
        "start_offset",
        "end_offset",
        "original_text"
      ],
      "title": "SourceSpanV1",
      "type": "object"
    },
    "TransliterationCandidateV1": {
      "additionalProperties": false,
      "properties": {
        "alignment": {
          "$ref": "#/$defs/AlignmentMapV1"
        },
        "calibration_status": {
          "$ref": "#/$defs/CalibrationStatus",
          "default": "UNCALIBRATED"
        },
        "candidate_id": {
          "title": "Candidate Id",
          "type": "string"
        },
        "is_identity": {
          "default": false,
          "title": "Is Identity",
          "type": "boolean"
        },
        "kind": {
          "$ref": "#/$defs/CandidateKind"
        },
        "provenance": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Provenance",
          "type": "array"
        },
        "rank": {
          "minimum": 1,
          "title": "Rank",
          "type": "integer"
        },
        "ranking_score": {
          "title": "Ranking Score",
          "type": "number"
        },
        "reason_codes": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Reason Codes",
          "type": "array"
        },
        "requires_review": {
          "default": false,
          "title": "Requires Review",
          "type": "boolean"
        },
        "script": {
          "$ref": "#/$defs/CandidateScript"
        },
        "surface": {
          "title": "Surface",
          "type": "string"
        },
        "uncertainty_class": {
          "$ref": "#/$defs/UncertaintyClass",
          "default": "MODERATE"
        }
      },
      "required": [
        "candidate_id",
        "surface",
        "script",
        "kind",
        "rank",
        "ranking_score",
        "alignment"
      ],
      "title": "TransliterationCandidateV1",
      "type": "object"
    },
    "TransliterationHypothesisV1": {
      "additionalProperties": false,
      "properties": {
        "aggregate_ranking_score": {
          "default": 0.0,
          "title": "Aggregate Ranking Score",
          "type": "number"
        },
        "alignment": {
          "anyOf": [
            {
              "$ref": "#/$defs/AlignmentMapV1"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "authoritative": {
          "default": false,
          "title": "Authoritative",
          "type": "boolean"
        },
        "candidate_refs": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Candidate Refs",
          "type": "array"
        },
        "hypothesis_id": {
          "title": "Hypothesis Id",
          "type": "string"
        },
        "preview_surface": {
          "default": "",
          "title": "Preview Surface",
          "type": "string"
        },
        "status": {
          "default": "CANDIDATE_ONLY",
          "title": "Status",
          "type": "string"
        }
      },
      "required": [
        "hypothesis_id"
      ],
      "title": "TransliterationHypothesisV1",
      "type": "object"
    },
    "TransliterationSpanV1": {
      "additionalProperties": false,
      "properties": {
        "candidates": {
          "default": [],
          "items": {
            "$ref": "#/$defs/TransliterationCandidateV1"
          },
          "title": "Candidates",
          "type": "array"
        },
        "decision_reason_codes": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Decision Reason Codes",
          "type": "array"
        },
        "disposition": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Disposition"
        },
        "eligibility": {
          "$ref": "#/$defs/EligibilityDecision"
        },
        "identity_candidate_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Identity Candidate Id"
        },
        "is_ambiguous": {
          "default": false,
          "title": "Is Ambiguous",
          "type": "boolean"
        },
        "is_name_like": {
          "default": false,
          "title": "Is Name Like",
          "type": "boolean"
        },
        "is_protected": {
          "default": false,
          "title": "Is Protected",
          "type": "boolean"
        },
        "policy_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Policy Version"
        },
        "raw_span": {
          "$ref": "#/$defs/SourceSpanV1"
        },
        "review_reason_codes": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Review Reason Codes",
          "type": "array"
        },
        "review_required": {
          "default": false,
          "title": "Review Required",
          "type": "boolean"
        },
        "source_language_form": {
          "title": "Source Language Form",
          "type": "string"
        },
        "span_id": {
          "title": "Span Id",
          "type": "string"
        },
        "truncated": {
          "default": false,
          "title": "Truncated",
          "type": "boolean"
        }
      },
      "required": [
        "span_id",
        "raw_span",
        "source_language_form",
        "eligibility"
      ],
      "title": "TransliterationSpanV1",
      "type": "object"
    },
    "TransliterationStatus": {
      "enum": [
        "NOT_RUN",
        "COMPLETE",
        "PARTIAL",
        "DEGRADED",
        "FAILED",
        "SKIPPED"
      ],
      "title": "TransliterationStatus",
      "type": "string"
    },
    "UncertaintyClass": {
      "enum": [
        "HIGH_EVIDENCE",
        "MODERATE",
        "LOW_EVIDENCE",
        "AMBIGUOUS",
        "ABSTAIN"
      ],
      "title": "UncertaintyClass",
      "type": "string"
    }
  },
  "$id": "https://mokxya.local/contracts/v1/TransliterationBundleV1.json",
  "additionalProperties": false,
  "properties": {
    "abstention_count": {
      "default": 0,
      "minimum": 0,
      "title": "Abstention Count",
      "type": "integer"
    },
    "analysis_status": {
      "$ref": "#/$defs/TransliterationStatus",
      "default": "NOT_RUN"
    },
    "candidate_count": {
      "default": 0,
      "minimum": 0,
      "title": "Candidate Count",
      "type": "integer"
    },
    "eligible_span_count": {
      "default": 0,
      "minimum": 0,
      "title": "Eligible Span Count",
      "type": "integer"
    },
    "error_codes": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Error Codes",
      "type": "array"
    },
    "hypotheses": {
      "default": [],
      "items": {
        "$ref": "#/$defs/TransliterationHypothesisV1"
      },
      "title": "Hypotheses",
      "type": "array"
    },
    "identity_only_count": {
      "default": 0,
      "minimum": 0,
      "title": "Identity Only Count",
      "type": "integer"
    },
    "matching_view": {
      "default": "RAW",
      "title": "Matching View",
      "type": "string"
    },
    "max_candidates_per_span": {
      "default": 5,
      "title": "Max Candidates Per Span",
      "type": "integer"
    },
    "max_hypotheses": {
      "default": 5,
      "title": "Max Hypotheses",
      "type": "integer"
    },
    "offset_unit": {
      "default": "UNICODE_CODE_POINT",
      "title": "Offset Unit",
      "type": "string"
    },
    "resource_hash": {
      "default": "",
      "title": "Resource Hash",
      "type": "string"
    },
    "resource_version": {
      "default": "mai-07.1.0",
      "title": "Resource Version",
      "type": "string"
    },
    "runtime_version": {
      "default": "mai-07.1.0",
      "title": "Runtime Version",
      "type": "string"
    },
    "schema_version": {
      "title": "Schema Version",
      "type": "string"
    },
    "source_authority": {
      "default": "RAW",
      "title": "Source Authority",
      "type": "string"
    },
    "span_results": {
      "default": [],
      "items": {
        "$ref": "#/$defs/TransliterationSpanV1"
      },
      "title": "Span Results",
      "type": "array"
    },
    "truncated_count": {
      "default": 0,
      "minimum": 0,
      "title": "Truncated Count",
      "type": "integer"
    },
    "warnings": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Warnings",
      "type": "array"
    }
  },
  "title": "TransliterationBundleV1",
  "type": "object",
  "x-mai-schema-version": "1.0.0"
}
