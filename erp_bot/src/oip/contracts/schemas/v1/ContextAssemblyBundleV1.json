{
  "$defs": {
    "ContextAssemblyStatus": {
      "enum": [
        "NOT_RUN",
        "COMPLETE",
        "PARTIAL",
        "FAILED"
      ],
      "title": "ContextAssemblyStatus",
      "type": "string"
    },
    "ContextFreshness": {
      "enum": [
        "HOT",
        "WARM",
        "COLD",
        "UNKNOWN"
      ],
      "title": "ContextFreshness",
      "type": "string"
    },
    "ContextSliceCandidateV1": {
      "additionalProperties": false,
      "properties": {
        "applied": {
          "default": false,
          "title": "Applied",
          "type": "boolean"
        },
        "exclude_reason_codes": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Exclude Reason Codes",
          "type": "array"
        },
        "freshness": {
          "$ref": "#/$defs/ContextFreshness",
          "default": "UNKNOWN"
        },
        "include_reason_codes": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Include Reason Codes",
          "type": "array"
        },
        "included": {
          "default": false,
          "title": "Included",
          "type": "boolean"
        },
        "kind": {
          "$ref": "#/$defs/ContextSliceKind"
        },
        "priority": {
          "default": 0,
          "title": "Priority",
          "type": "integer"
        },
        "slice_id": {
          "title": "Slice Id",
          "type": "string"
        },
        "source_label": {
          "default": "REQUEST",
          "title": "Source Label",
          "type": "string"
        },
        "surface_summary": {
          "default": "",
          "title": "Surface Summary",
          "type": "string"
        },
        "tokens_est": {
          "default": 0,
          "minimum": 0,
          "title": "Tokens Est",
          "type": "integer"
        }
      },
      "required": [
        "slice_id",
        "kind"
      ],
      "title": "ContextSliceCandidateV1",
      "type": "object"
    },
    "ContextSliceKind": {
      "enum": [
        "TRUSTED_SCOPE",
        "ACTIVE_DRAFT",
        "TURN_RELATION",
        "REFERENCE_COREFERENCE",
        "UNRESOLVED_CLARIFICATION",
        "ACTIVE_UI_CONTEXT",
        "CONVERSATION_ID",
        "UNKNOWN"
      ],
      "title": "ContextSliceKind",
      "type": "string"
    },
    "MemoryExpiryClass": {
      "enum": [
        "SESSION",
        "CONVERSATION",
        "TEMPORARY",
        "NONE"
      ],
      "title": "MemoryExpiryClass",
      "type": "string"
    },
    "MemoryPolicyV1": {
      "additionalProperties": false,
      "properties": {
        "cross_company_allowed": {
          "default": false,
          "title": "Cross Company Allowed",
          "type": "boolean"
        },
        "erp_facts_source": {
          "default": "ERP_PREFERRED",
          "title": "Erp Facts Source",
          "type": "string"
        },
        "expiry_class": {
          "$ref": "#/$defs/MemoryExpiryClass",
          "default": "CONVERSATION"
        },
        "max_slices": {
          "default": 8,
          "minimum": 0,
          "title": "Max Slices",
          "type": "integer"
        },
        "max_tokens": {
          "default": 1200,
          "minimum": 0,
          "title": "Max Tokens",
          "type": "integer"
        },
        "read_allowed": {
          "default": true,
          "title": "Read Allowed",
          "type": "boolean"
        },
        "write_allowed": {
          "default": false,
          "title": "Write Allowed",
          "type": "boolean"
        }
      },
      "title": "MemoryPolicyV1",
      "type": "object"
    }
  },
  "$id": "https://mokxya.local/contracts/v1/ContextAssemblyBundleV1.json",
  "additionalProperties": false,
  "properties": {
    "active_task_present": {
      "default": false,
      "title": "Active Task Present",
      "type": "boolean"
    },
    "analysis_status": {
      "$ref": "#/$defs/ContextAssemblyStatus",
      "default": "NOT_RUN"
    },
    "company_id_echo": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Company Id Echo"
    },
    "draft_mutations": {
      "default": 0,
      "minimum": 0,
      "title": "Draft Mutations",
      "type": "integer"
    },
    "error_codes": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Error Codes",
      "type": "array"
    },
    "excluded_count": {
      "default": 0,
      "minimum": 0,
      "title": "Excluded Count",
      "type": "integer"
    },
    "included_count": {
      "default": 0,
      "minimum": 0,
      "title": "Included Count",
      "type": "integer"
    },
    "memory_policy": {
      "$ref": "#/$defs/MemoryPolicyV1"
    },
    "memory_writes": {
      "default": 0,
      "minimum": 0,
      "title": "Memory Writes",
      "type": "integer"
    },
    "runtime_version": {
      "default": "mai-16.0.1-slice1",
      "title": "Runtime Version",
      "type": "string"
    },
    "schema_version": {
      "title": "Schema Version",
      "type": "string"
    },
    "silent_applications": {
      "default": 0,
      "minimum": 0,
      "title": "Silent Applications",
      "type": "integer"
    },
    "slices": {
      "default": [],
      "items": {
        "$ref": "#/$defs/ContextSliceCandidateV1"
      },
      "title": "Slices",
      "type": "array"
    },
    "source_authority": {
      "default": "REQUEST",
      "title": "Source Authority",
      "type": "string"
    },
    "tenant_id_echo": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Tenant Id Echo"
    },
    "token_budget": {
      "default": 1200,
      "minimum": 0,
      "title": "Token Budget",
      "type": "integer"
    },
    "tokens_estimated": {
      "default": 0,
      "minimum": 0,
      "title": "Tokens Estimated",
      "type": "integer"
    },
    "unresolved_clarification_present": {
      "default": false,
      "title": "Unresolved Clarification Present",
      "type": "boolean"
    },
    "warnings": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Warnings",
      "type": "array"
    }
  },
  "title": "ContextAssemblyBundleV1",
  "type": "object",
  "x-mai-schema-version": "1.0.0"
}
