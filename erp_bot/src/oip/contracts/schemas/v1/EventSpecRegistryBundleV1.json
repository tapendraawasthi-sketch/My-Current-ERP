        },
        "optional_fields": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Optional Fields",
          "type": "array"
        },
        "prohibited_assumptions": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Prohibited Assumptions",
          "type": "array"
        },
        "required_fields": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Required Fields",
          "type": "array"
        },
        "selected": {
          "default": false,
          "title": "Selected",
          "type": "boolean"
        },
        "spec_id": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Spec Id",
          "type": "string"
        }
