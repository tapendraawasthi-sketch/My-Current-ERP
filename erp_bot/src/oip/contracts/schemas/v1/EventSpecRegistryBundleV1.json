            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Intent Hint"
        },
        "match_rank": {
          "default": 0,
          "minimum": 0,
          "title": "Match Rank",
          "type": "integer"
        },
        "match_reason_codes": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Match Reason Codes",
          "type": "array"
